<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.siema.siemaexamproject.gui.ActivityLogsController"
      stylesheets="@helpers/app.css" styleClass="admin-content" spacing="18">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Activity Logs" styleClass="section-title" />
    </HBox>

    <!-- Filters Section -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="boxFilterField" promptText="Filter by Box..." HBox.hgrow="ALWAYS" styleClass="search-field,search-box" />
        <TextField fx:id="docFilterField" promptText="Filter by Document..." HBox.hgrow="ALWAYS" styleClass="search-field,search-box" />
        <TextField fx:id="fileFilterField" promptText="Filter by File ID..." HBox.hgrow="ALWAYS" styleClass="search-field,search-box" />
        <TextField fx:id="userFilterField" promptText="Filter by Username..." HBox.hgrow="ALWAYS" styleClass="search-field,search-box" />

        <Button text="Apply Filters" onAction="#handleApplyFilters" styleClass="primary-btn" />
    </HBox>

    <!-- Table Section -->
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="logsTable" fixedCellSize="30" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="160" />
                <TableColumn fx:id="userColumn" text="Username" prefWidth="120" />
                <TableColumn fx:id="fileIdColumn" text="File ID" prefWidth="260" />
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="200" />
                <TableColumn fx:id="detailsColumn" text="Details" prefWidth="250" />
            </columns>
        </TableView>
    </VBox>
</VBox>