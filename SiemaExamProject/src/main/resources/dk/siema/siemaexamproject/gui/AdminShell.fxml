<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.siema.siemaexamproject.gui.AdminShellController"
            stylesheets="@helpers/app.css" styleClass="admin-root">
    <top>
        <HBox styleClass="admin-top-tabs" spacing="6">
            <Button fx:id="usersTabButton" text="User Management" styleClass="admin-tab-button-selected" onAction="#showUsers" />
            <Button fx:id="profilesTabButton" text="Scanning Profiles" styleClass="admin-tab-button" onAction="#showProfiles" />
            <Button fx:id="logsTabButton" text="Activity Logs" styleClass="admin-tab-button" onAction="#showLogs" />
        </HBox>
    </top>
    <center>
        <StackPane fx:id="adminContentContainer" styleClass="content-root" />
    </center>
</BorderPane>
