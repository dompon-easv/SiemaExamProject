<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dk.siema.siemaexamproject.gui.LoginViewController"
           stylesheets="@helpers/app.css" styleClass="login-root">
    <VBox styleClass="surface-card,login-card" alignment="CENTER">
        <VBox alignment="CENTER" spacing="12">
            <HBox alignment="CENTER" spacing="9">
                <StackPane styleClass="brand-box">
                    <Label text="▣" styleClass="brand-icon" />
                </StackPane>
                <Label text="Visione" styleClass="login-header-title" />
            </HBox>
            <Label text="Document Scanner Access" styleClass="login-subtitle" />
        </VBox>

        <VBox spacing="15">
            <VBox styleClass="form-box">
                <Label text="Username" styleClass="form-label" />
                <StackPane styleClass="overlay-field" alignment="CENTER_LEFT">
                    <TextField fx:id="usernameField" promptText="Placeholder" styleClass="form-input" />
                    <Label text="◦" styleClass="field-icon" translateX="-118" />
                </StackPane>
            </VBox>

            <VBox styleClass="form-box">
                <Label text="Password" styleClass="form-label" />
                <StackPane styleClass="overlay-field" alignment="CENTER_LEFT">
                    <PasswordField fx:id="passwordField" promptText="Placeholder" styleClass="form-input" />
                    <Label text="○" styleClass="field-icon" translateX="-118" />
                </StackPane>
            </VBox>

            <Button text="Sign In" styleClass="primary-button" maxWidth="1.7976931348623157E308" onAction="#signIn" defaultButton="true"/>
        </VBox>
    </VBox>
</StackPane>
