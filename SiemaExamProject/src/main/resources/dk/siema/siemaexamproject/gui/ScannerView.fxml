<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="scanner-root" stylesheets="@helpers/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.siema.siemaexamproject.gui.ScannerViewController">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox styleClass="sidebar">

            <VBox styleClass="sidebar-section">
                <Button maxWidth="1.7976931348623157E308" onAction="#onStartNewScan" styleClass="primary-button" text="⟳ Start New Scan" />
            </VBox>

            <Region styleClass="sidebar-divider" />

            <VBox styleClass="sidebar-section">
                <Label styleClass="sidebar-title" text="Active Profile" />

                <ComboBox fx:id="profileComboBox" maxWidth="1.7976931348623157E308" styleClass="profile-combo" />

                <Label fx:id="profileDescriptionLabel" styleClass="sidebar-subtext" text="Standard invoice documents" wrapText="true" />
            </VBox>

            <Region styleClass="sidebar-divider" />

            <!-- ================= RECENT SCANS ================= -->
            <VBox spacing="6" styleClass="sidebar-section" VBox.vgrow="ALWAYS">

                <Label styleClass="sidebar-title" text="Document Structure" />

                <TreeView fx:id="documentTree" styleClass="tree-view" VBox.vgrow="ALWAYS" />

            </VBox>
        </VBox>
    </left>

    <!-- ================= CENTER AREA ================= -->
    <center>
        <BorderPane>

            <!-- TOP TOOLBAR -->
            <top>
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="content-toolbar">

                    <!-- LEFT SIDE -->
                    <HBox alignment="CENTER_LEFT" spacing="12">

                        <Label fx:id="fileNameLabel" styleClass="page-title" text="Awaiting selection" />

                        <Label styleClass="badge" text="Page 1 of 3" />

                        <Label fx:id="scanStatusLabel" styleClass="tree-text" text="Ready" />
                    </HBox>

                    <!-- PUSH CENTER -->
                    <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="rotationValueLbl" text="0°" />
               <Slider fx:id="rotationSlider" max="360.0" />

                     <Button onAction="#onRotateAction" styleClass="tool-button" text="↻" />

                    <!-- CENTER BUTTONS -->
                    <HBox alignment="CENTER" spacing="6">
                        <Button onAction="#onZoomInAction" styleClass="tool-button" text="+" />
                        <Button onAction="#onZoomOutAction" styleClass="tool-button" text="−" />

                    </HBox>

                    <!-- PUSH RIGHT -->
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- RIGHT SIDE -->
                    <Button onAction="#onExportAction" styleClass="top-action-button" text="⇩ Export" />

                </HBox>
            </top>

            <!-- DOCUMENT PREVIEW -->
            <center>
                <VBox alignment="CENTER" spacing="18" styleClass="preview-area">
               <StackPane fx:id="previewContainer">
                  <children>
      
                          <!-- IMAGE AREA -->
                          <ScrollPane fx:id="imageContainer" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="document-card" vbarPolicy="NEVER" />
                  </children>
               </StackPane>

                    <!-- PAGINATION -->
                    <HBox alignment="CENTER" spacing="12" styleClass="pagination-bar">

                        <Button onAction="#onPreviousPageAction" styleClass="pagination-button" text="‹" />
                        <Label fx:id="pageInfoLbl" styleClass="tree-text" text="Page 1 of 3" />
                        <Button onAction="#onNextPageAction" styleClass="pagination-button" text="›" />

                    </HBox>

                </VBox>
            </center>

        </BorderPane>
    </center>

</BorderPane>
