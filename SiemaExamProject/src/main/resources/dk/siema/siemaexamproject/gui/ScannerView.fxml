<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.siema.siemaexamproject.gui.ScannerViewController"
            stylesheets="@helpers/app.css"
            styleClass="scanner-root">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox styleClass="sidebar">

            <VBox styleClass="sidebar-section">
                <Button text="⟳ Start New Scan"
                        onAction="#onStartNewScan"
                        styleClass="primary-button"
                        maxWidth="1.7976931348623157E308"/>
            </VBox>

            <Region styleClass="sidebar-divider"/>

            <VBox styleClass="sidebar-section">
                <Label text="Active Profile" styleClass="sidebar-title"/>

                <ComboBox fx:id="profileComboBox"
                          styleClass="profile-combo"
                          maxWidth="1.7976931348623157E308"/>

                <Label fx:id="profileDescriptionLabel"
                       text="Standard invoice documents"
                       styleClass="sidebar-subtext"
                       wrapText="true"/>
            </VBox>

            <Region styleClass="sidebar-divider"/>

            <!-- ================= RECENT SCANS ================= -->
            <VBox spacing="6" VBox.vgrow="ALWAYS" styleClass="sidebar-section">

                <Label text="Document Structure" styleClass="sidebar-title"/>

                <TreeView fx:id="documentTree"
                          VBox.vgrow="ALWAYS"
                          styleClass="tree-view"/>

            </VBox>
        </VBox>
    </left>

    <!-- ================= CENTER AREA ================= -->
    <center>
        <BorderPane>

            <!-- TOP TOOLBAR -->
            <top>
                <HBox styleClass="content-toolbar"
                      alignment="CENTER_LEFT"
                      spacing="12">

                    <!-- LEFT INFO AREA -->
                    <HBox alignment="CENTER_LEFT" spacing="12">

                        <Label text="Invoice_2026_001.tiff"
                               styleClass="page-title"/>

                        <Label text="Page 1 of 3"
                               styleClass="badge"/>

                        <!-- ✅ STATUS LABEL (THIS FIXES YOUR NULL ERROR) -->
                        <Label fx:id="welcomeText"
                               text="Ready"
                               styleClass="tree-text"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- RIGHT ACTION AREA -->
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <HBox spacing="3">
                            <Button text="⟳" styleClass="tool-button"/>
                            <Button text="⊕" styleClass="tool-button"/>
                            <Button text="⊖" styleClass="tool-button"/>
                    <HBox alignment="CENTER" spacing="6">

                        <HBox spacing="3" alignment="CENTER">
                            <Button text="↻" styleClass="tool-button"/>
                            <Button text="+" styleClass="tool-button"/>
                            <Button text="−" styleClass="tool-button"/>
                        </HBox>

                        <Button text="⇩ Export" styleClass="top-action-button"/>
                    </HBox>

                </HBox>
            </top>

            <!-- DOCUMENT PREVIEW -->
            <center>
                <VBox styleClass="preview-area"
                      alignment="CENTER"
                      spacing="18">

                    <!-- IMAGE AREA -->
                    <FlowPane fx:id="imageContainer"
                              alignment="CENTER"
                              hgap="10"
                              vgap="10"
                              styleClass="document-card"/>

                    <!-- PAGINATION -->
                    <HBox styleClass="pagination-bar"
                          alignment="CENTER"
                          spacing="12">

                        <Button text="‹" styleClass="pagination-button"/>
                        <Label text="Page 1 of 3" styleClass="tree-text"/>
                        <Button text="›" styleClass="pagination-button"/>

                    </HBox>

                </VBox>
            </center>

        </BorderPane>
    </center>

</BorderPane>