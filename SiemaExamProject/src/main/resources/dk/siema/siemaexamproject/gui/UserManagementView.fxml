<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.siema.siemaexamproject.gui.UserManagementController"
      stylesheets="@helpers/app.css" styleClass="admin-content" spacing="18">
    <HBox alignment="CENTER_LEFT">
        <Label text="User Management" styleClass="section-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="＋ Add user" styleClass="top-action-button" onAction="#showAddUser"/>
    </HBox>

    <VBox styleClass="table-card">
        <TableView fx:id="usersTable" fixedCellSize="30">
            <columns>
                <TableColumn fx:id="usernameColumn" text="Username" prefWidth="140" />
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="170" />
                <TableColumn fx:id="roleColumn" text="Role" prefWidth="80" />
                <TableColumn fx:id="profileAccessColumn" text="Profile Access" prefWidth="260" />
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="80" />
            </columns>
        </TableView>
    </VBox>
</VBox>
