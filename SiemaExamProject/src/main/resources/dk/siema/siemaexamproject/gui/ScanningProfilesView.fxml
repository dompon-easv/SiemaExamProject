<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.siema.siemaexamproject.gui.ScanningProfilesViewController"
      stylesheets="@helpers/app.css" styleClass="admin-content" spacing="18">
    <HBox alignment="CENTER_LEFT">
        <Label text="Scanning Profiles" styleClass="section-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="＋ Add profile" styleClass="top-action-button" onAction="#showAddProfile" />
    </HBox>

    <VBox styleClass="table-card">
        <TableView fx:id="profilesTable" fixedCellSize="30">
            <columns>
                <TableColumn fx:id="profileNameColumn" text="Profile Name" prefWidth="180" />
                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250" />
                <TableColumn fx:id="settingsColumn" text="Settings" prefWidth="450" />
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="80" />
            </columns>
        </TableView>
    </VBox>
</VBox>
