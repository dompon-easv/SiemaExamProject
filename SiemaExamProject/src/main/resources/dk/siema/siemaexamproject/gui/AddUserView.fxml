<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dk.siema.siemaexamproject.gui.AddEditUserController"
           styleClass="content-root">

    <!-- overlay -->
    <VBox styleClass="modal-overlay" alignment="CENTER">

        <!-- modal card -->
        <VBox styleClass="surface-card modal-card" spacing="12">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <!-- dynamic title -->
            <Label fx:id="titleLabel"
                   text="Add User"
                   styleClass="section-title"/>

            <VBox spacing="6">
                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="usernameField"
                           promptText="Enter username"
                           styleClass="text-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Email" styleClass="form-label"/>
                <TextField fx:id="emailField"
                           promptText="Enter email"
                           styleClass="text-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Role" styleClass="form-label"/>
                <ComboBox fx:id="roleCombo"
                          promptText="Select role"
                          styleClass="profile-combo"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Profile Access" styleClass="form-label"/>
                <ComboBox fx:id="clientFilterComboBox" promptText="Filter by Client..." />
                <ListView fx:id="profilesList" prefHeight="150"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter password"
                               styleClass="text-input"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-text"/>

            <HBox spacing="12" alignment="CENTER_RIGHT">

                <Button text="Cancel"
                        styleClass="secondary-button"
                        onAction="#handleCancel"/>

                <Button text="Save"
                        styleClass="primary-button"
                        onAction="#handleSave"/>
            </HBox>

        </VBox>
    </VBox>

</StackPane>