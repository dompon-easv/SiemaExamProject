<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.SplitPane?>

<SplitPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="dk.siema.siemaexamproject.gui.MainController">

    <!-- LEFT SIDE: DOCUMENT STRUCTURE -->
    <VBox spacing="10.0">

        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Label fx:id="welcomeText" text="Documents"/>

        <Button text="Load TIFF Images" onAction="#onLoadAllImages"/>

        <!-- TREE STRUCTURE -->
        <TreeView fx:id="documentTree" prefWidth="250.0"/>

    </VBox>

    <!-- RIGHT SIDE: IMAGE PREVIEW -->
    <VBox spacing="10.0">

        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <ScrollPane fitToWidth="true">
            <content>
                <FlowPane fx:id="imageContainer" hgap="10" vgap="10"/>
            </content>
        </ScrollPane>

    </VBox>

</SplitPane>